{
  "entities": {
    "users": {
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID from Firebase Auth"
        },
        "name": {
          "type": "string",
          "description": "Full name of the user"
        },
        "email": {
          "type": "string",
          "description": "Email address of the user"
        },
        "photoURL": {
          "type": "string",
          "description": "Google avatar or custom profile photo URL"
        },
        "city": {
          "type": "string",
          "description": "Selected default city in India"
        },
        "points": {
          "type": "number",
          "description": "Karma/Reward points earned"
        },
        "badges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of earned civic badges"
        },
        "reportsSubmitted": {
          "type": "number",
          "description": "Total report events count"
        },
        "reportsVerified": {
          "type": "number",
          "description": "Total verified resolved complaints count"
        },
        "createdAt": {
          "type": "string",
          "description": "Account registration timestamp"
        },
        "lastLogin": {
          "type": "string",
          "description": "Last login recorded timestamp"
        }
      }
    },
    "reports": {
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "agentContext": { "type": "object", "description": "The final integrated AgentContext state" }
      }
    },
    "agentExecutions": {
      "properties": {
        "reportId": { "type": "string", "description": "Unified workflow or report reference ID" },
        "timestamp": { "type": "string", "description": "Execution event timestamp" },
        "agentName": { "type": "string", "description": "Name of the agent" },
        "status": { "type": "string", "description": "Execution status: Pending, Running, Completed, Failed" },
        "executionTime": { "type": "number", "description": "Total agent processing duration in ms" },
        "outputSummary": { "type": "string", "description": "Concise summary of agent shared-state output or error messages" }
      }
    },
    "notifications": {
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Owner user ID" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "description": "Notification level / type" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    },
    "analytics": {
      "properties": {
        "wardName": { "type": "string" },
        "city": { "type": "string" },
        "wardRiskIndex": { "type": "number" },
        "hotspotScore": { "type": "number" },
        "densityCluster": { "type": "string" },
        "reportsCount": { "type": "number" },
        "lastUpdated": { "type": "string" }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
